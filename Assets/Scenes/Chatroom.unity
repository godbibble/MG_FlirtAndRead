  m_Script: {fileID: 11500000, guid: d534c06d4f37bc5448a7ff8dd684e436, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ChatManager
  chatContentFolder: {fileID: 1329757937}
  scrollRect: {fileID: 416599490}
  aureliaBubblePrefab: {fileID: 4897804907005258398, guid: 576ba588cb3b56845ab24e0af06490ee, type: 3}
  vladBubblePrefab: {fileID: 1266609626951204319, guid: 265228440046b46469e7e6f100fc0b89, type: 3}
  lovometerSlider: {fileID: 605027823}
  answerButtons:
  - {fileID: 427035472}
  - {fileID: 143874028}
  - {fileID: 160053356}
  successPanel: {fileID: 384683939}
  nextLevelButton: {fileID: 1063602380}
  failPanel: {fileID: 524759849}
  retryButton: {fileID: 630584264}
  dialogueFlow:
  - nodeName: Einstieg
    answers:
    - answerText: Hey xD. Habe gesehen, dass du Chemie studierst. In welchem Semseter
        bist du? Vielleicht gehen wir zur gleichen Uni?
      lovometerPoints: 5
      aureliaReaction: Hi^^. Bin jetzt im 3. Semster an der UNB. Wie sieht's bei
        dir aus?
    - answerText: Was geht? An welcher Uni bist du?
      lovometerPoints: 0
      aureliaReaction: Hey, bin an der UNB. Und du?
    - answerText: Hey Schnecke! Wo studierst du?
      lovometerPoints: -5
      aureliaReaction: Hey, bin an der UNB. Und du?
    isLastNode: 0
  - nodeName: Gemeinsamkeiten
    answers:
    - answerText: Mega, ich auch. 5. Semester. Was machst du sonst so?
      lovometerPoints: 0
      aureliaReaction: "Ich lese gerne im Park, aktuell aber nur drinnen, Schnee
        und B\xFCcher vertragen sich ja nicht so gut xD. Sonst schaue ich auch gerne
        Naturdokus. "
    - answerText: Was ein Zufall. Ich bin auch an der UNB, im 5. Semester. Was machst
        du gerne in deiner Freizeit?
      lovometerPoints: 5
      aureliaReaction: "Ich lese gerne im Park, aktuell aber nur drinnen, Schnee
        und B\xFCcher vertragen sich ja nicht so gut xD. Sonst schaue ich auch gerne
        Naturdokus."
    isLastNode: 0
  - nodeName: Reaktion  auf Hobbies
    answers:
    - answerText: Lesen im Park? Klingt voll langweilig, ich zocke lieber. Aber Hauptsache
        du sitzt nicht nur vor der Glotze.
      lovometerPoints: -10
      aureliaReaction: "Naja, jedem das Seine. Manchmal ist es drinnen halt einfach
        gem\xFCtlicher."
    - answerText: "Oh ja, nasse Buchseiten sind der Endgegner. Naturdokus sind mega!
        Hast du die letzte Woche, \xFCber Tiefseewesen, gesehen?"
      lovometerPoints: 10
      aureliaReaction: "Haha, ja voll! Und ja, die Doku habe ich gesehen, die Leuchtfische
        sind super faszinierend. Aber ab und zu muss ich trotz K\xE4lte mal raus,
        sonst kriege ich noch Lagerkoller."
    - answerText: Stimmt, bei dem Wetter liest es sich drinnen besser. Ich schaue
        meistens eher Serien statt Dokus.
      lovometerPoints: 0
      aureliaReaction: Na ja, jedem das Seine. Solange kein Schneesturm kommt, gehe
        ich aktuell aber auch gerne raus, einfach etwas spazieren.
    isLastNode: 0
  - nodeName: Wintermarkt
    answers:
    - answerText: Absolut, bisschen frische Luft muss sein! Gegen den Lagerkoller
        hilft am besten Bewegung. Warst du dieses Jahr eigentlich schon auf dem Wintermarkt
        im Stadtpark?
      lovometerPoints: 10
      aureliaReaction: "Habe nur geh\xF6rt, dass der Markt sehr sch\xF6n sein soll.
        Aber da war ich noch nicht."
    - answerText: "Geh doch einfach ins Fitnessstudio, da ist es warm. Oder besorg
        dir ein Laufband f\xFCr die Wohnung, haha. Wie w\xE4re es mit dem Wintermarkt,
        bin da heute eh und hab Zeit f\xFCr dich."
      lovometerPoints: -15
      aureliaReaction: "Wei\xDF nicht..."
    - answerText: "Gegen Lagerkoller hilft nur Ablenkung. Ich muss sp\xE4ter sowieso
        noch kurz raus. Kennst du den Wintermarkt hier in der N\xE4he?"
      lovometerPoints: 5
      aureliaReaction: "Habe nur geh\xF6rt, dass der Markt sehr sch\xF6n sein soll.
        Aber da war ich noch nicht."
    isLastNode: 0
  - nodeName: Date-Einladung
    answers:
    - answerText: "Hast du Lust, da heute Nachmittag zusammen hinzugehen? Ich wei\xDF,
        wo es die besten S\xFC\xDFigkeiten gibt."
      lovometerPoints: 5
      aureliaReaction: 
    - answerText: Komm. Lass uns da treffen.
      lovometerPoints: -5
      aureliaReaction: 
    isLastNode: 1
